@model IEnumerable<GatherWise.Domain.Entities.Booking>

@{
    ViewData["Title"] = "Event Bookings";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-dark">Event Bookings Log</h1>
            <p class="text-muted">Track reservations, dates, and total financial invoicing statements.</p>
        </div>
        <div>
            <a class="btn btn-success btn-lg shadow-sm" asp-action="Create">Reserve a New Venue</a>
        </div>
    </div>

    <hr class="mb-4" />

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm p-5" role="alert">
            <h4 class="alert-heading fw-bold">No Active Reservations!</h4>
            <p class="mb-0">There are no client bookings present in the system database right now.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Booking ID</th>
                            <th>Venue</th>
                            <th>Event Date / Slot</th>
                            <th>Guests</th>
                            <th>Total Price</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#GW-@booking.Id</td>
                                <td class="fw-semibold text-primary">@booking.Venue?.Name</td>
                                <td class="small">
                                    <strong>@booking.Slot?.Date.ToString("dd-MMM-yyyy")</strong><br />
                                    <span class="text-muted">@booking.Slot?.StartTime.ToString(@"hh\:mm") - @booking.Slot?.EndTime.ToString(@"hh\:mm")</span>
                                </td>
                                <td>@booking.EstimatedGuests</td>
                                <td class="fw-bold text-success">₹@booking.TotalPrice.ToString("N2")</td>
                                <td>
                                    <span class="badge rounded-pill px-3 py-2 bg-warning text-dark">@booking.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>