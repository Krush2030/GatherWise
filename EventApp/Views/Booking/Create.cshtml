@model GatherWise.Domain.Entities.Booking

@{
    ViewData["Title"] = "Book a Venue";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-success text-white p-4 rounded-top">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-journal-check me-2"></i>Secure Event Reservation</h4>
                    <p class="text-white-50 mb-0 small">Select a venue and connect an open operational calendar timeline slot.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Choose Venue</label>
                            <select id="venueDropdown" asp-for="VenueId" class="form-select" asp-items="ViewBag.VenueId">
                                <option value="">-- Select Property --</option>
                            </select>
                            <span asp-validation-for="VenueId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold d-block mb-2">Available Operational Timeline Windows</label>
                            <div id="calendar-loading-spinner" class="text-muted small d-none mb-2">
                                <div class="spinner-border spinner-border-sm text-success me-1" role="status"></div> Loading platform registry schedules...
                            </div>
                            
                            <input type="hidden" id="hiddenSlotId" asp-for="SlotId" required />
                            <span asp-validation-for="SlotId" class="text-danger small d-block mb-2"></span>

                            <div id="visual-calendar-grid" class="row g-2">
                                <div class="col-12 text-center text-muted py-4 border rounded-3 bg-light">
                                    <i class="bi bi-calendar-x fs-3 d-block mb-1 text-secondary"></i>
                                    <span class="small">Please select a venue property above to populate active operational dates.</span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="EstimatedGuests" class="form-label fw-semibold">Estimated Guest Attendance</label>
                            <input asp-for="EstimatedGuests" type="number" class="form-control" placeholder="e.g., 150" />
                            <span asp-validation-for="EstimatedGuests" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 p-3 bg-light border rounded-3">
                            <label class="form-label text-muted small d-block mb-1">Total Calculated Billing Value</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white fw-bold text-success">₹</span>
                                <input asp-for="TotalPrice" type="number" step="0.01" class="form-control fw-bold fs-5 text-success" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="TotalPrice" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                            <button type="submit" class="btn btn-success px-4 rounded-pill shadow-sm">Confirm Booking</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .slot-card-interactive {
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        border: 2px solid #e0e0e0;
    }

        .slot-card-interactive:hover:not(.disabled) {
            border-color: #198754;
            background-color: #f8fff9;
            transform: translateY(-2px);
        }

        .slot-card-interactive.selected-slot {
            border-color: #198754 !important;
            background-color: #d1e7dd !important;
            color: #0f5132 !important;
        }

        .slot-card-interactive.disabled {
            cursor: not-allowed;
            background-color: #e9ecef;
            opacity: 0.6;
            border-color: #dee2e6;
        }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script type="text/javascript">
        document.getElementById("venueDropdown").addEventListener("change", async function () {
        const venueId = this.value;
        const gridContainer = document.getElementById("visual-calendar-grid");
        const spinner = document.getElementById("calendar-loading-spinner");
        const hiddenInput = document.getElementById("hiddenSlotId");

        hiddenInput.value = ""; // Reset selections upon switching properties
            
        if (!venueId) {
        gridContainer.innerHTML = `
        <div class="col-12 text-center text-muted py-4 border rounded-3 bg-light">
        <i class="bi bi-calendar-x fs-3 d-block mb-1 text-secondary"></i>
        <span class="small">Please select a venue property above to populate active operational dates.</span>
        </div>`;
        return;
        }

        try {
        spinner.classList.remove("d-none");
        const response = await fetch('/Booking/GetAvailableSlots?venueId=' + venueId);
        const slots = await response.json();
        spinner.classList.add("d-none");

        gridContainer.innerHTML = ""; // Wipe container grid clean

        if (slots.length === 0) {
        gridContainer.innerHTML = `
        <div class="col-12 text-center text-danger py-4 border border-danger rounded-3 bg-danger bg-opacity-10">
        <i class="bi bi-exclamation-triangle fs-3 d-block mb-1"></i>
        <span class="small fw-semibold">No operational slots are currently configured for this venue property.</span>
        </div>`;
        return;
        }

        slots.forEach(slot => {
        const col = document.createElement("div");
        col.className = "col-sm-6 col-md-4 mb-2";

        const card = document.createElement("div");
        card.className = `slot-card-interactive p-3 rounded-3 text-center h-100 bg-white shadow-sm ${slot.isBooked ? 'disabled' : ''}`;
                    
        card.innerHTML = `
        <div class="fw-bold text-dark small mb-1"><i class="bi bi-calendar-event me-1 text-success"></i> ${slot.date}</div>
        <div class="text-muted x-small">${slot.startTime} - ${slot.endTime}</div>
        ${slot.isBooked ? '<span class="badge bg-danger mt-2 rounded-pill x-small">Booked out</span>' : '<span class="badge bg-outline-success mt-2 rounded-pill x-small text-success border border-success">Available</span>'}
        `;

        if (!slot.isBooked) {
        card.addEventListener("click", function() {
        // Clear previous selected styling attributes across sibling options
        document.querySelectorAll('.slot-card-interactive').forEach(c => c.classList.remove('selected-slot'));
        // Apply custom design borders indicating an active option select state
        card.classList.add('selected-slot');
        hiddenInput.value = slot.id;
        });
        }

        col.appendChild(card);
        gridContainer.appendChild(col);
        });

        } catch (error) {
        spinner.classList.add("d-none");
        console.error("Error building interactive slot matrix mapping:", error);
        }
        });
    </script>
}