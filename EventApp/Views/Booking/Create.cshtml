@model GatherWise.Domain.Entities.Booking

@{
    ViewData["Title"] = "Book a Venue";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-success text-white p-4 rounded-top">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-journal-check me-2"></i>Secure Event Reservation</h4>
                    <p class="text-white-50 mb-0 small">Select a venue and connect an open operational calendar timeline slot.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Choose Venue</label>
                            <select id="venueDropdown" asp-for="VenueId" class="form-select" asp-items="ViewBag.VenueId">
                                <option value="">-- Select Property --</option>
                            </select>
                            <span asp-validation-for="VenueId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Available Calendar Slots</label>
                            <select id="slotDropdown" asp-for="SlotId" class="form-select" disabled>
                                <option value="">-- Please select a venue first --</option>
                            </select>
                            <span asp-validation-for="SlotId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="EstimatedGuests" class="form-label fw-semibold">Estimated Guest Attendance</label>
                            <input asp-for="EstimatedGuests" type="number" class="form-control" placeholder="e.g., 150" />
                            <span asp-validation-for="EstimatedGuests" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 p-3 bg-light border rounded-3">
                            <label class="form-label text-muted small d-block mb-1">Total Calculated Billing Value</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white fw-bold text-success">₹</span>
                                <input asp-for="TotalPrice" type="number" step="0.01" class="form-control fw-bold fs-5 text-success" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="TotalPrice" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                            <button type="submit" class="btn btn-success px-4 rounded-pill shadow-sm">Confirm Booking</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script type="text/javascript">
        document.getElementById("venueDropdown").addEventListener("change", function () {
        var venueId = this.value;
        var slotDropdown = document.getElementById("slotDropdown");

        if (!venueId) {
        slotDropdown.innerHTML = '<option value="">-- Please select a venue first --</option>';
        slotDropdown.disabled = true;
        return;
        }

        // Fetch available time slots from our AJAX Endpoint
        fetch('/Booking/GetAvailableSlots?venueId=' + venueId)
        .then(response => response.json())
        .then(data => {
        slotDropdown.innerHTML = '<option value="">-- Select an Available Slot --</option>';
        if (data.length === 0) {
        slotDropdown.innerHTML = '<option value="">No slots available for this venue</option>';
        slotDropdown.disabled = true;
        } else {
        data.forEach(function (slot) {
        var option = document.createElement("option");
        option.value = slot.id;
        option.text = slot.text;
        slotDropdown.appendChild(option);
        });
        slotDropdown.disabled = false;
        }
        });
        });
    </script>
}