@model GatherWise.Domain.Entities.Slot

@{
    ViewData["Title"] = "Add Availability Slot";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-primary text-white p-4 rounded-top">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-calendar-plus me-2"></i>Schedule Venue Availability</h4>
                    <p class="text-white-50 mb-0 small">Open up single or custom operational blocks for client event booking.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Select Target Property</label>
                            <select asp-for="VenueId" class="form-select" asp-items="ViewBag.VenueId">
                                <option value="">-- Choose a Venue --</option>
                            </select>
                            <span asp-validation-for="VenueId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Date" class="form-label fw-semibold">Calendar Date</label>
                            <input asp-for="Date" type="date" class="form-control" />
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label asp-for="StartTime" class="form-label fw-semibold">Opening Time</label>
                                <input asp-for="StartTime" type="time" class="form-control" />
                                <span asp-validation-for="StartTime" class="text-danger small"></span>
                            </div>
                            <div class="col-6">
                                <label asp-for="EndTime" class="form-label fw-semibold">Closing Time</label>
                                <input asp-for="EndTime" type="time" class="form-control" />
                                <span asp-validation-for="EndTime" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm">Open Slot</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}