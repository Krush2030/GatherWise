@model GatherWise.Domain.Entities.Slot

@{
    ViewData["Title"] = "Remove Slot";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow rounded-3">
                <div class="card-header bg-danger text-white p-4">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-trash-fill me-2"></i>Remove Availability Slot?</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <h4 class="text-dark fw-bold mb-2">@Model.Venue?.Name</h4>
                    <p class="text-muted">
                        Scheduled for <strong>@Model.Date.ToString("dd-MMM-yyyy")</strong> <br />
                        From @Model.StartTime.ToString(@"hh\:mm") to @Model.EndTime.ToString(@"hh\:mm")
                    </p>

                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2 justify-content-center">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                            <button type="submit" class="btn btn-danger px-4 rounded-pill shadow">Delete Slot</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>