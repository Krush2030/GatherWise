@model IEnumerable<GatherWise.Domain.Entities.Payment>
@using GatherWise.Domain.Enums

@{
    ViewData["Title"] = "Billing & Invoices";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-dark">Billing & Invoices</h1>
            <p class="text-muted">Track transaction pipelines, operational deposits, and payment receipts.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["InfoMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <hr class="mb-4" />

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm p-5" role="alert">
            <h4 class="alert-heading fw-bold">No Invoices Found</h4>
            <p class="mb-0 text-secondary">There are currently no transactional entries linked to your profile database records.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Invoice ID</th>
                            <th>Reservation ID</th>
                            <th>Venue</th>
                            <th>Execution Date</th>
                            <th>Billed Amount</th>
                            <th>Status</th>
                            <th>Method</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#INV-@payment.Id</td>
                                <td class="fw-semibold">#GW-@payment.BookingId</td>
                                <td class="text-primary fw-semibold">@payment.Booking?.Venue?.Name</td>
                                <td class="small">
                                    @payment.Booking?.Slot?.Date.ToString("dd-MMM-yyyy")
                                </td>
                                <td class="fw-bold text-success">₹@payment.Amount.ToString("N2")</td>
                                <td>
                                    @if (payment.Status == PaymentStatus.FullyPaid)
                                    {
                                        <span class="badge rounded-pill px-3 py-2 bg-success">Fully Paid</span>
                                    }
                                    else if (payment.Status == PaymentStatus.Pending)
                                    {
                                        <span class="badge rounded-pill px-3 py-2 bg-warning text-dark">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill px-3 py-2 bg-danger">@payment.Status.ToString()</span>
                                    }
                                </td>
                                <td class="text-muted small">@(string.IsNullOrEmpty(payment.PaymentMethod) ? "—" : payment.PaymentMethod)</td>
                                
                                <td class="text-end pe-4">
                                    @if (User.IsInRole("Event Host") && payment.Status == PaymentStatus.Pending)
                                    {
                                        <a asp-action="Checkout" asp-route-id="@payment.Id" class="btn btn-sm btn-success rounded-pill px-3 shadow-sm">
                                            <i class="bi bi-credit-card me-1"></i> Pay Invoice
                                        </a>
                                    }
                                    else if (payment.Status == PaymentStatus.FullyPaid)
                                    {
                                        <div class="d-inline-flex gap-2">
                                            <span class="text-success small d-flex align-items-center me-2">
                                                <i class="bi bi-patch-check-fill me-1"></i> Settled
                                            </span>
                                            <a asp-action="Receipt" asp-route-id="@payment.Id" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                <i class="bi bi-file-earmark-arrow-down me-1"></i> Invoice
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>