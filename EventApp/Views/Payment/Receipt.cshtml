@model GatherWise.Domain.Entities.Payment

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice_Receipt_INV_@Model.Id</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <style>
            body {
                background-color: #f8f9fa;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            .receipt-card {
                background: #ffffff;
                border: 1px solid #e0e0e0;
                border-radius: 8px;
            }
            /* Layout rules to isolate the document frame clean when printing */
            @@media print {
                body {
                    background-color: #ffffff;
                }

                .no-print {
                    display: none !important;
                }

                .receipt-card {
                    border: none !important;
                    box-shadow: none !important;
                    padding: 0 !important;
                    max-width: 100% !important;
                }
            }
    </style>
</head>
<body>

    <div class="container my-5">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4 no-print" style="max-width: 850px; margin: 0 auto;">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-1"></i> Back to Bills
            </a>
            <div class="d-flex gap-2">
                <button onclick="downloadInvoiceAsImage();" class="btn btn-outline-dark rounded-pill px-4 shadow-sm">
                    <i class="bi bi-filetype-png me-1"></i> Download Image (PNG)
                </button>
                <button onclick="window.print();" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-file-earmark-pdf me-1"></i> Print / Save PDF
                </button>
            </div>
        </div>

        <div id="invoice-capture-area" class="receipt-card p-5 shadow-sm mx-auto" style="max-width: 850px;">
            <div class="row border-bottom pb-4 mb-4 align-items-center">
                <div class="col-sm-6">
                    <h2 class="fw-bold text-success mb-1"><i class="bi bi-layers-half me-2"></i>GatherWise</h2>
                    <p class="text-muted small mb-0">Premium Public Venue Management Solutions</p>
                </div>
                <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
                    <h4 class="text-dark fw-bold mb-1">RECEIPT / INVOICE</h4>
                    <span class="text-secondary fw-semibold">Invoice Ref: #INV-@Model.Id</span>
                </div>
            </div>

            <div class="row mb-4 fs-6">
                <div class="col-sm-4 mb-3 mb-sm-0">
                    <span class="text-uppercase text-muted small d-block fw-bold tracking-wider">Billed To (Host)</span>
                    <strong class="text-dark">@((Model.Booking?.EventHost?.FullName) ?? Model.Booking?.EventHost?.UserName ?? "N/A")</strong>
                </div>
                <div class="col-sm-4 mb-3 mb-sm-0">
                    <span class="text-uppercase text-muted small d-block fw-bold tracking-wider">Venue Operator</span>
                    <strong class="text-dark">@((Model.Booking?.Venue?.Owner?.FullName) ?? Model.Booking?.Venue?.Owner?.UserName ?? "N/A")</strong>
                </div>
                <div class="col-sm-4 text-sm-end">
                    <span class="text-uppercase text-muted small d-block fw-bold tracking-wider">Transaction Timestamp</span>
                    <strong class="text-dark">@Model.PaymentDate.ToString("dd-MMM-yyyy hh:mm tt")</strong>
                </div>
            </div>

            <h5 class="fw-bold text-secondary mb-3 border-bottom pb-2">Reservation Framework Specifics</h5>
            <div class="row g-3 mb-4 bg-light p-3 rounded-3 border">
                <div class="col-md-6">
                    <span class="text-muted small d-block">Target Booking Registry Code</span>
                    <strong class="text-primary">#GW-@Model.BookingId</strong>
                </div>
                <div class="col-md-6">
                    <span class="text-muted small d-block">Property Venue Profile</span>
                    <strong class="text-dark">@Model.Booking?.Venue?.Name</strong>
                </div>
                <div class="col-md-6">
                    <span class="text-muted small d-block">Location Coordinates</span>
                    <strong class="text-dark"><i class="bi bi-geo-alt me-1"></i> @Model.Booking?.Venue?.Location</strong>
                </div>
                <div class="col-md-6">
                    <span class="text-muted small d-block">Timeline Execution Window</span>
                    <strong class="text-dark">
                        <i class="bi bi-calendar3 me-1"></i> @Model.Booking?.Slot?.Date.ToString("dd-MMM-yyyy")
                        <span class="text-muted fw-normal"> Mandatory (@Model.Booking?.Slot?.StartTime.ToString(@"hh\:mm") - @Model.Booking?.Slot?.EndTime.ToString(@"hh\:mm"))</span>
                    </strong>
                </div>
            </div>

            <h5 class="fw-bold text-secondary mb-3">Line Item Accounting Ledger</h5>
            <div class="table-responsive mb-4">
                <table class="table table-bordered align-middle">
                    <thead class="table-light text-secondary small text-uppercase">
                        <tr>
                            <th>Description / Line Item</th>
                            <th class="text-center" style="width: 20%;">Metrics</th>
                            <th class="text-end" style="width: 25%;">Line Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <strong>Venue Property Rental Charges</strong><br />
                                <span class="text-muted small">Flat base tariff calculation metrics applied to selected block.</span>
                            </td>
                            <td class="text-center text-muted">@Model.Booking?.EstimatedGuests Guests Max Cap</td>
                            <td class="text-end fw-semibold text-dark">₹@Model.Amount.ToString("N2")</td>
                        </tr>
                        <tr class="fs-5 table-light">
                            <td colspan="2" class="text-end fw-bold text-secondary">Grand Settlement Total:</td>
                            <td class="text-end fw-bold text-success">₹@Model.Amount.ToString("N2")</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="p-3 rounded-3 d-flex justify-content-between align-items-center bg-opacity-10 @(Model.Status == GatherWise.Domain.Enums.PaymentStatus.FullyPaid ? "bg-success text-success border border-success" : "bg-warning text-dark border border-warning")">
                <div>
                    <span class="small text-uppercase d-block fw-bold tracking-wide">Processing Pathway Matrix</span>
                    <strong class="small">Settled Via: @Model.PaymentMethod</strong>
                </div>
                <div class="text-end">
                    <span class="small text-uppercase d-block fw-bold tracking-wide">Ledger Balance State</span>
                    <span class="badge @(Model.Status == GatherWise.Domain.Enums.PaymentStatus.FullyPaid ? "bg-success" : "bg-warning text-dark") p-2 rounded-pill fs-6 uppercase">
                        <i class="bi bi-patch-check-fill me-1"></i> @Model.Status.ToString()
                    </span>
                </div>
            </div>
        
            <div class="text-center mt-5 border-top pt-3">
                <p class="text-muted small mb-0">Thank you for organizing your event with GatherWise platform utilities.</p>
                <p class="text-muted x-small">Electronic systemic certificate documentation — No manual physical signatures required.</p>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <script>
        function downloadInvoiceAsImage() {
        const targetElement = document.getElementById("invoice-capture-area");
            
        const renderOptions = {
        scale: 2,
        useCORS: true,
        backgroundColor: "#ffffff"
        };

        html2canvas(targetElement, renderOptions).then(canvas => {
        const imageUri = canvas.toDataURL("image/png");
                    
        const virtualLink = document.createElement("a");
        virtualLink.href = imageUri;
        virtualLink.download = "Invoice_Receipt_INV_@Model.Id" + ".png";
                    
        document.body.appendChild(virtualLink);
        virtualLink.click();
        document.body.removeChild(virtualLink);
        });
        }
    </script>
</body>
</html>