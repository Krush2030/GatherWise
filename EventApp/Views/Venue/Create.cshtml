@model GatherWise.Domain.Entities.Venue

@{
    ViewData["Title"] = "List a New Venue";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-success bg-opacity-10 text-success p-4 border-bottom border-success border-opacity-10 rounded-top">
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 bg-success text-white rounded-3 fs-3 leading-none">
                            <i class="bi bi-building shadow-sm"></i>
                        </div>
                        <div>
                            <h3 class="mb-0 fw-bold text-dark">List a New Venue</h3>
                            <p class="text-muted mb-0 small">Register your space parameters with up to 15 high-quality listing photos</p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <!-- ENCTYPE IS ABSOLUTELY MANDATORY FOR FILE UPLOADS -->
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <label asp-for="Name" class="form-label fw-semibold text-dark">Venue Title</label>
                                <input asp-for="Name" class="form-control" placeholder="e.g., Grand Palace Ballroom" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Location" class="form-label fw-semibold text-dark">Geographic Location / Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-geo-alt"></i></span>
                                    <input asp-for="Location" class="form-control border-start-0" placeholder="e.g., MG Road, Pune, Maharashtra" />
                                </div>
                                <span asp-validation-for="Location" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Capacity" class="form-label fw-semibold text-dark">Maximum Guest Capacity</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-people"></i></span>
                                    <input asp-for="Capacity" type="number" class="form-control border-start-0" placeholder="e.g., 500" />
                                </div>
                                <span asp-validation-for="Capacity" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PricePerSlot" class="form-label fw-semibold text-dark">Pricing Per Block Slot Allocation</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-success fw-bold">₹</span>
                                    <input asp-for="PricePerSlot" type="number" step="0.01" class="form-control border-start-0 text-success fw-semibold" placeholder="50000.00" />
                                </div>
                                <span asp-validation-for="PricePerSlot" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold text-dark">Description & Features Ledger</label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Outline features context..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <!-- FILE UPLOAD DROPZONE FIELD -->
                            <div class="col-12">
                                <label class="form-label fw-semibold text-dark">Upload Gallery Assets (Max 15 Images)</label>
                                <div class="card border-dashed p-4 text-center bg-light cursor-pointer position-relative hover-bg-light transition-all rounded-3" id="dropzoneContainer">
                                    <input type="file" name="files" id="venueImagesInput" multiple accept="image/*" class="position-absolute top-0 start-0 w-100 h-100 opacity-0 cursor-pointer" style="z-index: 5;" />
                                    <i class="bi bi-images text-success display-4 mb-2 d-block"></i>
                                    <span class="d-block text-dark fw-medium">Click or Drag & Drop to attach images</span>
                                    <span class="text-muted small">Supports JPEG, PNG formats up to 15 files max</span>
                                </div>
                                <span class="text-danger small" id="imageValidationMessage"></span>
                                @Html.ValidationMessage("Images", "", new { @class = "text-danger small" })
                            </div>

                            <!-- DYNAMIC PREVIEW WRAPPER AREA -->
                            <div class="col-12">
                                <div id="previewGalleryGrid" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3 mt-1"></div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Discard</a>
                            <button type="submit" class="btn btn-success px-4 rounded-pill shadow-sm fw-semibold" id="submitFormBtn">Save Listing</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- Instant JS Client-Side File Previews Rendering Logic -->
    <script>
        document.getElementById('venueImagesInput').addEventListener('change', function (event) {
            const previewGrid = document.getElementById('previewGalleryGrid');
            const feedbackMsg = document.getElementById('imageValidationMessage');
            const submitBtn = document.getElementById('submitFormBtn');
            const files = event.target.files;
            
            previewGrid.innerHTML = '';
            feedbackMsg.textContent = '';
            submitBtn.disabled = false;

            if (files.length > 15) {
                feedbackMsg.textContent = 'Operational Alert: Selection bounds exceeded. You cannot append more than 15 images to a venue catalog registry line item.';
                submitBtn.disabled = true;
                return;
            }

            Array.from(files).forEach(file => {
                if (!file.type.startsWith('image/')) return;

                const reader = new FileReader();
                reader.onload = function (e) {
                    const col = document.createElement('div');
                    col.className = 'col animate fade-in';
                    col.innerHTML = `
                        <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden position-relative">
                            <img src="${e.target.result}" class="card-img-top object-fit-cover" style="height: 110px;" alt="Preview asset">
                            <div class="bg-dark bg-opacity-75 text-white text-truncate text-center py-1 px-2 position-absolute bottom-0 w-100" style="font-size: 0.7rem;">
                                ${(file.size / 1024).toFixed(1)} KB
                            </div>
                        </div>
                    `;
                    previewGrid.appendChild(col);
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}