@model GatherWise.Domain.Entities.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <!-- High-visibility Danger Header Header -->
                <div class="bg-danger bg-opacity-10 text-danger p-4 border-bottom border-danger border-opacity-10">
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 bg-danger text-white rounded-3 fs-4 leading-none">
                            <i class="bi bi-exclamation-triangle shadow-sm"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold text-dark">Are you absolutely sure?</h4>
                            <p class="text-muted mb-0 small">This operational line removal cannot be reversed.</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 text-center">
                    <div class="my-3">
                        <i class="bi bi-building-x text-danger opacity-20" style="font-size: 5rem;"></i>
                    </div>
                    <h3 class="text-dark fw-bold mb-1">@Model.Name</h3>
                    <p class="text-muted small"><i class="bi bi-geo-alt me-1"></i> @Model.Location</p>
                    
                    <!-- Structured Warnings Constraint Block -->
                    <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-warning-emphasis text-start my-4 p-3 rounded-3" role="alert">
                        <div class="d-flex gap-2">
                            <i class="bi bi-info-circle-fill mt-0.5"></i>
                            <div>
                                <strong class="text-uppercase small d-block mb-1 tracking-wider">System Constraints Notification</strong>
                                <span class="small text-secondary">If this listing possesses active calendar slots, confirmed reservations, or dependency records, execution may be blocked by relational database integrity configurations.</span>
                            </div>
                        </div>
                    </div>

                    <!-- Action Interface -->
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2 justify-content-center pt-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel, Keep Listing</a>
                            <button type="submit" class="btn btn-danger px-4 rounded-pill shadow-sm fw-semibold">Confirm Deletion</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>