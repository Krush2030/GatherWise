@model GatherWise.Domain.Entities.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow rounded-3">
                <div class="card-header bg-danger text-white p-4">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Are you absolutely sure?</h4>
                    <p class="mb-0 text-white-50 small">This action cannot be undone. Please confirm you want to delete this venue catalog entry.</p>
                </div>
                <div class="card-body p-4 text-center">
                    <i class="bi bi-trash3 text-danger display-1 mb-3"></i>
                    <h3 class="text-dark fw-bold mb-1">@Model.Name</h3>
                    <p class="text-muted"><i class="bi bi-geo-alt"></i> @Model.Location</p>
                    
                    <div class="alert alert-warning border shadow-sm text-start mt-3 mb-4" role="alert">
                        <small class="fw-bold d-block text-uppercase mb-1"><i class="bi bi-info-circle-fill"></i> Warning Constraints:</small>
                        <small class="text-secondary">If this venue has any scheduled calendar slots or dependencies, the action might fail or cascade delete related data depending on current data integrity filters.</small>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2 justify-content-center">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">No, Keep It</a>
                            <button type="submit" class="btn btn-danger px-4 rounded-pill shadow">Yes, Delete Entry</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>