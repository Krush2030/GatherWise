@model IEnumerable<GatherWise.Domain.Entities.Venue>
@using System.Security.Claims

@{
    ViewData["Title"] = "Explore Venues";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-primary">Discover Spectacular Venues</h1>
            <p class="text-muted">Find and book the perfect setting for your next unforgettable event.</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Venue Owner"))
        {
            <div>
                <a class="btn btn-success btn-lg shadow-sm" asp-action="Create">+ List a New Venue</a>
            </div>
        }
    </div>

    <hr class="mb-4" />

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm p-5" role="alert">
            <h4 class="alert-heading fw-bold">No Venues Found!</h4>
            <p class="mb-0">Our database is currently empty. Try running a seed script or add your very first venue to get started.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var venue in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-3 hover-shadow transition-all">
                        <div class="bg-light d-flex align-items-center justify-content-center border-bottom rounded-top" style="height: 180px;">
                            <i class="bi bi-building text-secondary display-1"></i>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-dark">@venue.Name</h5>
                            <p class="card-text text-muted mb-2">
                                <i class="bi bi-geo-alt-fill text-danger"></i> @venue.Location
                            </p>
                            <p class="card-text text-truncate small text-secondary">
                                @venue.Description
                            </p>
                            
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                                <div>
                                    <span class="text-muted small d-block">Capacity</span>
                                    <strong class="text-dark">@venue.Capacity Guests</strong>
                                </div>
                                <div class="text-end">
                                    <span class="text-muted small d-block">Price / Slot</span>
                                    <strong class="text-success fs-5">₹@venue.PricePerSlot.ToString("N2")</strong>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-3 pt-0 d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@venue.Id" class="btn btn-outline-primary w-100 rounded-pill">View Details</a>
                            
                            @if (User.IsInRole("Admin") || venue.OwnerId == currentUserId)
                            {
                                <a asp-action="Edit" asp-route-id="@venue.Id" class="btn btn-outline-warning rounded-pill px-3" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                <a asp-action="Delete" asp-route-id="@venue.Id" class="btn btn-outline-danger rounded-pill px-3" title="Delete"><i class="bi bi-trash"></i></a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>