@model GatherWise.Domain.Entities.Venue

@{
    ViewData["Title"] = "Edit Venue";
    int currentImageCount = Model.Images?.Count ?? 0;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="bg-success bg-opacity-10 text-success p-4 border-bottom border-success border-opacity-10 rounded-top">
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 bg-success text-white rounded-3 fs-3 leading-none">
                            <i class="bi bi-pencil-square shadow-sm"></i>
                        </div>
                        <div>
                            <h3 class="mb-0 fw-bold text-dark">Modify Venue Details</h3>
                            <p class="text-muted mb-0 small">Update parameters, description, or attach new property photos (Max 15 total)</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="OwnerId" />

                        <div class="row g-4">
                            <div class="col-12">
                                <label asp-for="Name" class="form-label fw-semibold text-dark">Venue Title</label>
                                <input asp-for="Name" class="form-control" placeholder="e.g., Grand Palace Ballroom" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Location" class="form-label fw-semibold text-dark">Geographic Location / Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-geo-alt"></i></span>
                                    <input asp-for="Location" class="form-control border-start-0" placeholder="e.g., MG Road, Pune, Maharashtra" />
                                </div>
                                <span asp-validation-for="Location" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Capacity" class="form-label fw-semibold text-dark">Maximum Guest Capacity</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-people"></i></span>
                                    <input asp-for="Capacity" type="number" class="form-control border-start-0" />
                                </div>
                                <span asp-validation-for="Capacity" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PricePerSlot" class="form-label fw-semibold text-dark">Pricing Per Block Slot Allocation</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-success fw-bold">₹</span>
                                    <input asp-for="PricePerSlot" type="number" step="0.01" class="form-control border-start-0 text-success fw-semibold" />
                                </div>
                                <span asp-validation-for="PricePerSlot" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold text-dark">Description & Features Ledger</label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Outline specific features or accommodations..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            @if (currentImageCount > 0)
                            {
                                <div class="col-12">
                                    <label class="form-label fw-semibold text-dark">Currently Saved Gallery Images (@currentImageCount/15)</label>
                                    <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3 p-2 bg-light rounded-3 border">
                                        @foreach (var img in Model.Images)
                                        {
                                            <div class="col">
                                                <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                                                    <img src="@img.ImagePath" class="card-img-top object-fit-cover" style="height: 100px;" alt="Saved asset">
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="col-12">
                                <label class="form-label fw-semibold text-dark">Upload Additional Images</label>
                                <div class="card border-dashed p-4 text-center bg-light cursor-pointer position-relative hover-bg-light transition-all rounded-3" id="dropzoneContainer">
                                    <input type="file" name="files" id="venueImagesInput" multiple accept="image/*" class="position-absolute top-0 start-0 w-100 h-100 opacity-0 cursor-pointer" style="z-index: 5;" />
                                    <i class="bi bi-cloud-arrow-up text-success display-4 mb-2 d-block"></i>
                                    <span class="d-block text-dark fw-medium">Click or Drag new photos here</span>
                                    <span class="text-muted small">Combined images cannot exceed the maximum count limit of 15 files</span>
                                </div>
                                <span class="text-danger small" id="imageValidationMessage"></span>
                                @Html.ValidationMessage("Images", "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-12">
                                <div id="previewGalleryGrid" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3 mt-1"></div>
                            </div>

                            <div class="col-12">
                                <div class="form-check form-switch p-3 bg-light rounded-3 border border-translucent d-flex align-items-center gap-2">
                                    <input class="form-check-input ms-0 mt-0" type="checkbox" role="switch" id="IsAvailableSwitch" asp-for="IsAvailable">
                                    <label class="form-check-label fw-semibold text-dark" for="IsAvailableSwitch">Set Venue Status as Active & Available for Booking</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-5 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Discard Changes</a>
                            <button type="submit" class="btn btn-success px-4 rounded-pill shadow-sm fw-semibold" id="submitFormBtn">Update Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const existingCount = parseInt('@currentImageCount');
        
        document.getElementById('venueImagesInput').addEventListener('change', function (event) {
            const previewGrid = document.getElementById('previewGalleryGrid');
            const feedbackMsg = document.getElementById('imageValidationMessage');
            const submitBtn = document.getElementById('submitFormBtn');
            const files = event.target.files;
            
            previewGrid.innerHTML = '';
            feedbackMsg.textContent = '';
            submitBtn.disabled = false;

            if (files.length + existingCount > 15) {
                feedbackMsg.textContent = `Operational Alert: Limit Exceeded. This venue already contains ${existingCount} images. You can only upload ${15 - existingCount} more photos.`;
                submitBtn.disabled = true;
                return;
            }

            Array.from(files).forEach(file => {
                if (!file.type.startsWith('image/')) return;

                const reader = new FileReader();
                reader.onload = function (e) {
                    const col = document.createElement('div');
                    col.className = 'col animate fade-in';
                    col.innerHTML = `
                        <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden position-relative">
                            <img src="${e.target.result}" class="card-img-top object-fit-cover" style="height: 90px;" alt="Pending upload">
                            <div class="bg-success text-white text-center py-0.5 position-absolute top-0 end-0 px-2 font-monospace rounded-bottom-start" style="font-size: 0.65rem;">
                                New
                            </div>
                        </div>
                    `;
                    previewGrid.appendChild(col);
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}