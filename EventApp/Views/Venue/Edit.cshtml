@model GatherWise.Domain.Entities.Venue

@{
    ViewData["Title"] = "Edit Venue";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-warning text-dark p-4 rounded-top">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-pencil-square border-end border-dark pe-2 me-2"></i>Modify Venue Details</h3>
                    <p class="text-dark-50 mb-0 small">Update parameters, description, or toggle availability settings for this property.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Name" class="form-label fw-semibold">Venue Name</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Location" class="form-label fw-semibold">Address / Location</label>
                                <input asp-for="Location" class="form-control" />
                                <span asp-validation-for="Location" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Capacity" class="form-label fw-semibold">Maximum Capacity (Guests)</label>
                                <input asp-for="Capacity" type="number" class="form-control" />
                                <span asp-validation-for="Capacity" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PricePerSlot" class="form-label fw-semibold">Price Per Slot (₹)</label>
                                <div class="input-group">
                                    <span class="input-group-text">₹</span>
                                    <input asp-for="PricePerSlot" type="number" step="0.01" class="form-control" />
                                </div>
                                <span asp-validation-for="PricePerSlot" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold">Description / Highlights</label>
                                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-3">
                                <div class="form-check form-switch p-3 bg-light rounded-3 border">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" asp-for="IsAvailable">
                                    <label class="form-check-label fw-semibold text-dark" asp-for="IsAvailable">Set Venue Status as Active & Available for Booking</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                            <button type="submit" class="btn btn-warning px-4 rounded-pill shadow-sm text-dark">Update Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}