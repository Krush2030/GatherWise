@model GatherWise.Domain.Entities.Venue
@using System.Security.Claims

@{
    ViewData["Title"] = "Venue Details";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwnVenue = Model.OwnerId == currentUserId;
}

<div class="container my-5">
    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        
        <div class="bg-dark text-white p-4 position-relative">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                        <h2 class="mb-0 fw-bold text-white">@Model.Name</h2>
                        @if (User.IsInRole("Admin"))
                        {
                            <span class="badge bg-light text-dark rounded-pill border small">Admin Core Entry</span>
                        }
                        @if (isOwnVenue)
                        {
                            <span class="badge bg-success rounded-pill small">Your Listing</span>
                        }
                    </div>
                    <p class="mb-0 opacity-75"><i class="bi bi-geo-alt-fill text-danger me-1"></i> @Model.Location</p>
                </div>
                <div>
                    <span class="badge @(Model.IsAvailable ? "bg-success bg-opacity-20 text-success border border-success border-opacity-20" : "bg-danger bg-opacity-20 text-danger border border-danger border-opacity-20") fs-6 px-4 py-2 rounded-pill">
                        <i class="bi bi-circle-fill me-1 small animate-pulse"></i> @(Model.IsAvailable ? "Active Catalog" : "Deactivated")
                    </span>
                </div>
            </div>
        </div>

        @if (Model.Images != null && Model.Images.Any())
        {
            <div id="venueCarousel" class="carousel slide bg-light border-bottom" data-bs-ride="carousel" style="max-height: 450px; overflow: hidden;">
                <div class="carousel-indicators">
                    @for (int i = 0; i < Model.Images.Count; i++)
                    {
                        <button type="button" data-bs-target="#venueCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "")"></button>
                    }
                </div>
                <div class="carousel-inner">
                    @{
                        int index = 0;
                    }
                    @foreach (var img in Model.Images)
                    {
                        <div class="carousel-item @(index == 0 ? "active" : "")" style="height: 450px;">
                            <img src="@img.ImagePath" class="d-block w-100 h-100 object-fit-cover" alt="Venue image asset">
                        </div>
                        index++;
                    }
                </div>
                @if (Model.Images.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#venueCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#venueCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                }
            </div>
        }

        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-5 border-md-end pe-md-4">
                    <h5 class="text-success text-uppercase small fw-bold tracking-wider mb-3">Operational Framework</h5>
                    
                    <div class="p-3 bg-light rounded-3 mb-3 d-flex align-items-center justify-content-between">
                        <div>
                            <label class="text-muted small d-block text-uppercase">Max Allowed Capacity</label>
                            <span class="fs-5 fw-bold text-dark">@Model.Capacity Guests</span>
                        </div>
                        <i class="bi bi-people text-secondary fs-3 opacity-50"></i>
                    </div>

                    <div class="p-3 bg-success bg-opacity-10 text-success rounded-3 d-flex align-items-center justify-content-between">
                        <div>
                            <label class="text-success-emphasis small d-block text-uppercase">Price / Scheduled Window</label>
                            <span class="fs-5 fw-bold">₹@Model.PricePerSlot.ToString("N2")</span>
                        </div>
                        <i class="bi bi-cash-stack fs-3 opacity-50"></i>
                    </div>
                </div>

                <div class="col-md-7 ps-md-4">
                    <h5 class="text-dark text-uppercase small fw-bold tracking-wider mb-3">Listing Profile & Amenities</h5>
                    <div class="bg-light p-4 rounded-3 h-100">
                        <p class="text-secondary mb-0 fs-6" style="white-space: pre-line; line-height: 1.6;">
                            @(string.IsNullOrEmpty(Model.Description) ? "No supplemental description context provided for this operational line record item." : Model.Description)
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-between mt-5 pt-3 border-top">
                <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill align-self-start">
                    <i class="bi bi-arrow-left me-1"></i> Back to Catalog
                </a>
                
                <div class="d-flex gap-2 w-100 w-sm-auto justify-content-end">
                    @if (User.IsInRole("Event Host") && !isOwnVenue)
                    {
                        <a asp-controller="Booking" asp-action="Create" asp-route-venueId="@Model.Id" class="btn btn-success px-4 rounded-pill shadow-sm fw-semibold">
                            <i class="bi bi-calendar-plus me-1"></i> Initiate Booking Block
                        </a>
                    }
                    @if (User.IsInRole("Admin") || isOwnVenue)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 rounded-pill shadow-sm text-dark fw-semibold">
                            <i class="bi bi-pencil-square me-1"></i> Edit Record
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4 rounded-pill">
                            <i class="bi bi-trash me-1"></i> Delete
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>