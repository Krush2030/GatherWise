@model GatherWise.Web.Models.Account.RegisterViewModel
@{
    ViewData["Title"] = "Create an Account";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-dark text-white p-4 text-center">
                    <h3 class="fw-bold mb-1">Join GatherWise</h3>
                    <p class="text-white-50 small mb-0">Select your specific ecosystem profile role to get started</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-semibold"></label>
                            <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SelectedRole" class="form-label fw-semibold"></label>
                            <select asp-for="SelectedRole" class="form-select" asp-items="@(new SelectList(ViewBag.Roles))">
                                <option value="">-- Choose Account Role Type --</option>
                            </select>
                            <span asp-validation-for="SelectedRole" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label asp-for="Password" class="form-label fw-semibold"></label>
                                <input asp-for="Password" class="form-control" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <div class="col-6">
                                <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                                <input asp-for="ConfirmPassword" class="form-control" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold shadow-sm mb-3">Sign Up</button>
                        <div class="text-center small">
                            <span class="text-muted">Already registered?</span> <a asp-action="Login" class="text-decoration-none fw-semibold">Login Here</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}